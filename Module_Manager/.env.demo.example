# Demo / test Firebase Hosting build — copy to `.env.demo` (gitignored), then: npm run build:demo
# See docs/deployment/DEMO_SITE.md

PUBLIC_DEMO_SITE=true
PUBLIC_DEMO_VISITOR_LOGIN=true

# Single-org demo (same codebase as multitenant; pins one Mongo tenant id — required for demo UX)
# Get id: npm run demo:seed (root) prints "Tenant ID", or copy SINGLE_TENANT_ID from API/ GCE .env
PUBLIC_SINGLE_TENANT_MODE=true
PUBLIC_SINGLE_TENANT_ID=
PUBLIC_SINGLE_TENANT_DISPLAY_NAME=WISPTools Demo ISP
