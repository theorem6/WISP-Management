# Copy to .env and set values for local dev / deployment.
# Single-tenant (one WISP): pin the organization id from your backend / Firestore.
# Leave unset or false for full multitenant (selector, tenant setup, multiple orgs).

# PUBLIC_SINGLE_TENANT_MODE=true
# PUBLIC_SINGLE_TENANT_ID=
# PUBLIC_SINGLE_TENANT_DISPLAY_NAME=

# Orange demo banner + /demo hub (test sites only)
# PUBLIC_DEMO_SITE=true

# Login: "Continue as demo visitor" (requires API DEMO_VISITOR_MODE — see docs/deployment/DEMO_VISITOR.md)
# PUBLIC_DEMO_VISITOR_LOGIN=true
