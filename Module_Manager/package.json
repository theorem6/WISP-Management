{
  "name": "wisptools-io",
  "version": "0.2.0",
  "description": "WISP Management – comprehensive WISP platform for planning, deployment, monitoring, and maintenance (wisptools.io)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "node --max-old-space-size=6144 node_modules/vite/bin/vite.js build && node scripts/postbuild-404.js",
    "build:check": "npm run build && ls -lh build/client/_app/immutable/entry/",
    "start": "node server.js",
    "start:original": "node build/index.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "deploy": "chmod +x deploy-to-firebase.sh && ./deploy-to-firebase.sh",
    "deploy:firebase": "npm run build && cd .. && firebase deploy --only hosting"
  },
  "dependencies": {
    "@arcgis/core": "^4.34.8",
    "@stripe/stripe-js": "^4.10.0",
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/leaflet": "^1.9.21",
    "echarts": "^6.0.0",
    "express": "^4.22.1",
    "firebase": "^11.1.0",
    "leaflet": "^1.9.4",
    "mongodb": "^6.21.0",
    "svelte": "^5.55.1",
    "vis-network": "^10.0.2"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@types/node": "^20.19.25",
    "cross-env": "^10.1.0",
    "svelte-check": "^4.3.4",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.4.21"
  },
  "overrides": {
    "cookie": "^0.7.2",
    "esbuild": "^0.25.0"
  }
}
