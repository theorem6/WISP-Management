# PayPal Configuration
# Get these from https://developer.paypal.com/dashboard/applications/sandbox
# For production, use Live credentials
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_ENVIRONMENT=sandbox
# Options: 'sandbox' or 'live'

# MongoDB Atlas (see backend-services/.env.example for full template)
MONGODB_URI=mongodb+srv://genieacs-user:<db_password>@cluster0.1radgkw.mongodb.net/?appName=Cluster0

# Server Port
PORT=3001

# Single-tenant API: when set, requests without X-Tenant-ID use this tenant (matches PUBLIC_SINGLE_TENANT_ID on the web app)
# SINGLE_TENANT_ID=

# Demo seed: optional Firebase Auth uid for auto UserTenant owner row
# DEMO_FIREBASE_USER_UID=
# DEMO_TENANT_SUBDOMAIN=wisptools-demo
# Required for npm run demo:reset only — use only with an isolated demo MongoDB
# ALLOW_DEMO_RESET=true

# Demo visitor login (IP-derived Firebase uid demo_v_*; see docs/deployment/DEMO_VISITOR.md)
# DEMO_VISITOR_MODE=true
# DEMO_VISITOR_TENANT_ID=
# DEMO_VISITOR_SALT=
# DEMO_VISITOR_MAX_CUSTOMERS=8
# DEMO_VISITOR_MAX_WORK_ORDERS=15
# DEMO_VISITOR_MAX_INCIDENTS=10
# DEMO_VISITOR_MAX_INVENTORY=8


# Firebase (if using service account file)
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_CLIENT_EMAIL=your_service_account_email
# FIREBASE_PRIVATE_KEY=your_private_key
